---
Checks: >
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  misc-*,
  performance-*,
  portability-*,
  readability-*,
  -readability-magic-numbers,
  -readability-identifier-length,
  -bugprone-easily-swappable-parameters,
  -bugprone-reserved-identifier,
  -cert-dcl37-c,
  -cert-dcl51-cpp,
  -cert-err33-c,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  -misc-include-cleaner,
  -misc-no-recursion,
  -performance-no-int-to-ptr,
  -readability-avoid-nested-conditional-operator,
  -readability-function-cognitive-complexity,
  -bugprone-assignment-in-if-condition,
  -bugprone-branch-clone

# Disabled checks, with rationale:
#
#   readability-magic-numbers / readability-identifier-length:
#     Noisy; harms readability when applied uniformly.
#
#   bugprone-easily-swappable-parameters:
#     Catches genuine "swapped (a, b)" bugs, but flags any pair of
#     same-typed parameters. Mitigation: functions with more than three
#     same-typed parameters take a named options struct instead.
#
#   bugprone-reserved-identifier (+ cert-dcl37-c, cert-dcl51-cpp aliases):
#     Flags _POSIX_C_SOURCE -- the standard feature-test macro POSIX
#     itself defines -- and the test harness's _a/_b macro-local temps.
#     Both uses are conventional.
#
#   cert-err33-c:
#     Flags every diagnostic fprintf(stderr, ...). For diagnostic logging
#     the return is genuinely uninteresting; littering the codebase with
#     (void) casts harms readability. Primary stdout writes are checked
#     manually.
#
#   clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling:
#     Recommends C11 Annex K (*_s functions). Annex K isn't supported by
#     glibc and is widely considered a failed standardization. The code
#     uses size-bounded functions with explicit, checked sizes.
#
#   misc-no-recursion:
#     Flags every tree-walking function (read_form, print_form, mark,
#     equal_p, ...). Recursion is the natural shape for these traversals.
#     The DoS-mitigation concern -- stack exhaustion from deeply-nested
#     inputs -- is addressed by the reader's depth limit (default 256)
#     and the evaluator's trampolined main loop (TCO eliminates the
#     common recursive case).
#
#   performance-no-int-to-ptr:
#     Fundamentally incompatible with the tagged-pointer value
#     representation: every heap-object accessor casts a mvalue
#     (a uintptr_t) back to a typed pointer. The check exists to
#     spot pessimization opportunities that don't apply to a value
#     model where the integer *is* the pointer (low-bit-tagged).
#
#   readability-avoid-nested-conditional-operator:
#     The eval / primitives modules use compact `cond ? a : b` chains
#     where the alternative is multi-line if/else that buries the
#     control structure. Mitigation: every nested ternary is short
#     (two levels max) and is exercised by tests.
#
#   readability-function-cognitive-complexity:
#     The evaluator's main loop and reader's list reader are
#     deliberately structured as single dispatching functions because
#     the alternative -- one function per special form -- spreads
#     the trampoline / protect-stack discipline across the codebase
#     and obscures it. Threshold 30 is hostile to the shape; the
#     functions are unit-tested end-to-end.
#
#   bugprone-assignment-in-if-condition:
#     The status-propagation pattern `if ((st = call(...)) != OK)` is
#     idiomatic in C error-handling code and produces tighter call
#     sites than the temporary-variable variant. The check is a
#     remnant of C++ style guidance.
#
#   bugprone-branch-clone:
#     The exit-code mapping switch in main.c lists every error code
#     individually for explicit -Wswitch-enum coverage; collapsing
#     identical arms would defeat that check's purpose.

WarningsAsErrors: ''
HeaderFilterRegex: '.*/(include|src|tests|examples)/.*'
FormatStyle: file
CheckOptions:
  - key: readability-function-cognitive-complexity.Threshold
    value: '30'
  - key: readability-identifier-naming.FunctionCase
    value: 'lower_case'
  - key: readability-identifier-naming.VariableCase
    value: 'lower_case'
  - key: readability-identifier-naming.MacroDefinitionCase
    value: 'UPPER_CASE'
  - key: readability-identifier-naming.EnumConstantCase
    value: 'UPPER_CASE'
